        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WPFPhysicsControlsLib;component/Resources/PhysicsSimResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converter:BooleanToVisibilityConverter x:Key="BoolConv"/>
            <converter:MultiVisibilityConverter x:Key="MultiVisConv"/>

